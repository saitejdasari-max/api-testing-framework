# ============================================================
# API Testing Framework - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Active Environment: dev | staging | production
ENV=dev

# ── Dev ────────────────────────────────────────────────────
DEV_BASE_URL=https://jsonplaceholder.typicode.com
DEV_API_VERSION=v1
DEV_TIMEOUT=30

# ── Staging ────────────────────────────────────────────────
STAGING_BASE_URL=https://staging.yourapi.com
STAGING_API_VERSION=v1
STAGING_TIMEOUT=30

# ── Production ─────────────────────────────────────────────
PROD_BASE_URL=https://api.yourapi.com
PROD_API_VERSION=v1
PROD_TIMEOUT=60

# ── Auth ───────────────────────────────────────────────────
AUTH_USERNAME=test_user
AUTH_PASSWORD=test_password
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here

# ── Retry ──────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=2

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_TO_FILE=true
